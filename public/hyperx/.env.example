# ================================================
# HyperX 環境變數設定
# 複製此檔案為 .env 並填入你的設定
# ================================================

# Hyperliquid API
HL_API_URL=https://api.hyperliquid.xyz
HL_WS_URL=wss://api.hyperliquid.xyz/ws

# 你的 Hyperliquid Agent Wallet 私鑰
# (在 Hyperliquid App > Settings > API 生成 Agent Wallet)
# 注意：永遠不要提交真實私鑰到 Git！
AGENT_PRIVATE_KEY=0xyour_agent_private_key_here

# 你的主錢包地址（用於查詢帳戶狀態）
MASTER_WALLET=0xyour_main_wallet_address

# 伺服器設定
PORT=3000
NODE_ENV=development

# 跟單引擎設定
COPY_ENGINE_ENABLED=true
MAX_CONCURRENT_COPIES=10
DEFAULT_SLIPPAGE=0.005
